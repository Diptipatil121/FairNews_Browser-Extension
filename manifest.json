{
  "manifest_version": 3,
  "name": "News Bias Analyzer",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.trycloudflare.com/*"
  ],
  "icons": {
    "16": "icon16.png"
  },
  "action": {
    "default_popup": "popup.html",
     "default_icon": {
      "16": "icon16.png"
    }
  }
}